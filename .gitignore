# Godot caches (do NOT commit)
.godot/
.import/

# Mono / C#
.mono/
.vs/
*.csproj
*.sln

# IDE/editor cruft
.idea/
.vscode/
*.user
*.tmp

# OS cruft
.DS_Store
Thumbs.db

# Android keystores (never commit — losing these locks you out of app updates)
*.keystore
*.jks

# Ignore build outputs
Builds/
*.exe
*.zip
*.pck
